---
import { testimonials } from '../../data/content';
---

<section class="section-pad" style="background:var(--color-inverse-canvas);">
  <div class="container-page">
    <p class="eyebrow reveal" style="color:var(--color-inverse-ink-muted);">Testimonials</p>
    <h2 class="display-lg reveal" data-reveal-delay="80" style="margin-top:12px; color:var(--color-inverse-ink); max-width:18ch;">
      What Karachi wears.
    </h2>

    <div class="grid md:grid-cols-3 gap-6 mt-12">
      {
        testimonials.map((t, i) => (
          <figure
            class="reveal card-testimonial m-0 flex flex-col"
            data-reveal-delay={i * 80}
          >
            <blockquote class="body-lg m-0" style="color:var(--color-ink); line-height:1.5;">
              “{t.quote}”
            </blockquote>
            <figcaption class="flex items-center gap-3 mt-6 pt-6" style="border-top:1px solid var(--color-hairline);">
              <span
                class="inline-flex items-center justify-center"
                style="width:44px;height:44px;border-radius:9999px;background:var(--color-surface-2);color:var(--color-ink);font-weight:500;font-size:15px;"
              >
                {t.initials}
              </span>
              <span>
                <span class="eyebrow" style="display:block; color:var(--color-ink);">{t.name}</span>
                <span class="caption" style="display:block; color:var(--color-ink-muted); margin-top:2px;">{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>