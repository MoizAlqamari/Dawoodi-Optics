---
---

<section id="top" class="relative" style="min-height: 100svh; overflow: hidden;">
  <!-- Background image with parallax -->
  <div class="absolute inset-0" style="z-index:0;">
    <img
      data-hero-img
      src="https://images.unsplash.com/photo-1577803645773-f96470509666?auto=format&fit=crop&w=1600&q=80"
      alt="Premium eyewear displayed in a bright boutique"
      class="w-full h-full object-cover"
      style="transform: scale(1.04); will-change: transform;"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, rgba(245,241,236,0.55) 0%, rgba(245,241,236,0.2) 35%, rgba(245,241,236,0.85) 100%);"
    >
    </div>
  </div>

  <div class="container-page relative" style="z-index:1; padding-top: 120px; padding-bottom: 64px; min-height: 100svh; display:flex; flex-direction:column; justify-content:center;">
    <p class="eyebrow reveal" style="color:var(--color-ink-muted);">
      Eyewear as it should feel — North Nazimabad, Karachi
    </p>
    <h1 class="display-xl reveal" data-reveal-delay="80" style="max-width: 14ch; margin-top: 16px;">
      See the world through better frames.
    </h1>
    <p class="subhead reveal" data-reveal-delay="160" style="max-width: 46ch; margin-top: 24px; color:var(--color-ink-muted);">
      A curated eyewear boutique where premium frames meet expert eye care.
      No clinics, no queues — just the right pair, fitted perfectly.
    </p>
    <div class="flex flex-wrap gap-3 reveal" data-reveal-delay="240" style="margin-top: 32px;">
      <a href="#frames" class="btn-primary btn-text no-underline">Explore Frames</a>
      <a href="#visit" class="btn-secondary btn-text no-underline">Book an Eye Test</a>
    </div>

    <div
      class="flex flex-wrap gap-x-8 gap-y-3 reveal"
      data-reveal-delay="320"
      style="margin-top: 56px;"
    >
      <span class="caption" style="color:var(--color-ink-subtle);">Oliver Peoples</span>
      <span class="caption" style="color:var(--color-ink-subtle);">Leica</span>
      <span class="caption" style="color:var(--color-ink-subtle);">Gentle Monster</span>
      <span class="caption" style="color:var(--color-ink-subtle);">Warby Parker</span>
    </div>
  </div>
</section>