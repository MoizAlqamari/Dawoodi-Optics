---

<section id="visit" class="section-pad">
  <div class="container-page">
    <div class="card-mockup reveal" style="border:1px solid var(--color-hairline); overflow:hidden;">
      <div class="grid lg:grid-cols-2">
        <div style="padding:48px;">
          <p class="eyebrow" style="color:var(--color-ink-muted);">Store Information</p>
          <h2 class="display-md" style="margin-top:12px; max-width:14ch;">
            Come try them on.
          </h2>
          <p class="body-lg" style="margin-top:16px; color:var(--color-ink-muted); max-width:40ch;">
            Walk in, or book a quiet slot with our optometrist. Either way, leave
            with frames that feel like they were made for you.
          </p>

          <dl class="mt-8 flex flex-col gap-5">
            <div>
              <dt class="caption" style="color:var(--color-ink-tertiary); text-transform:uppercase; letter-spacing:0.4px;">Address</dt>
              <dd class="body-lg m-0" style="margin-top:4px; color:var(--color-ink);">North Nazimabad, Karachi, Pakistan</dd>
            </div>
            <div>
              <dt class="caption" style="color:var(--color-ink-tertiary); text-transform:uppercase; letter-spacing:0.4px;">Hours</dt>
              <dd class="body-lg m-0" style="margin-top:4px; color:var(--color-ink);">Monday – Sunday · 11:00 – 21:00</dd>
            </div>
            <div>
              <dt class="caption" style="color:var(--color-ink-tertiary); text-transform:uppercase; letter-spacing:0.4px;">Contact</dt>
              <dd class="body-lg m-0" style="margin-top:4px; color:var(--color-ink);">+92 300 000 0000</dd>
            </div>
          </dl>

          <div class="flex flex-wrap gap-3 mt-8">
            <a href="tel:+923000000000" class="btn-primary btn-text no-underline">Call the store</a>
            <a href="#top" class="btn-secondary btn-text no-underline">Book an Eye Test</a>
          </div>
        </div>

        <div class="relative min-h-[280px] lg:min-h-full">
          <img
            src="https://images.unsplash.com/photo-1556013679-28b6a9d8a1e6?auto=format&fit=crop&w=1000&q=80"
            alt="Inside the Dawoodi Opticals boutique in Karachi"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>