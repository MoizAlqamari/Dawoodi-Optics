---
import { brands } from '../../data/content';
---

<section id="brands" class="section-pad" style="background:var(--color-surface-2);">
  <div class="container-page">
    <div class="mb-12 max-w-2xl">
      <p class="eyebrow reveal" style="color:var(--color-ink-muted);">Featured Brands</p>
      <h2 class="display-lg reveal" data-reveal-delay="80" style="margin-top:12px;">
        The houses we choose to carry.
      </h2>
      <p class="body-lg reveal" data-reveal-delay="160" style="margin-top:16px; color:var(--color-ink-muted);">
        A small, considered roster of the world's most respected eyewear makers.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        brands.map((brand, i) => (
          <article
            class="reveal card-surface flex flex-col"
            data-reveal-delay={i * 80}
            style="border:1px solid var(--color-hairline);"
          >
            <div
              class="overflow-hidden"
              style="border-radius: var(--radius-lg); aspect-ratio: 1/1; background:var(--color-surface-2);"
            >
              <img
                src={brand.image}
                alt={brand.name}
                loading="lazy"
                class="w-full h-full object-cover"
                style="transition: transform 0.6s cubic-bezier(0.16,1,0.3,1);"
                onmouseover="this.style.transform='scale(1.05)'"
                onmouseout="this.style.transform='scale(1)'"
              />
            </div>
            <h3 class="card-title" style="margin-top:16px;">{brand.name}</h3>
            <p class="body-sm" style="margin-top:6px; color:var(--color-ink-muted);">
              {brand.tagline}
            </p>
            <span class="caption" style="margin-top:10px; color:var(--color-ink-tertiary);">
              {brand.origin}
            </span>
          </article>
        ))
      }
    </div>
  </div>
</section>